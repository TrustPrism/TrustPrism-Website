# ============================================
# TrustPrism - Complete Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# Database Configuration
POSTGRES_USER=trustuser
POSTGRES_PASSWORD=trustpass
POSTGRES_DB=trustprism
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trustprism
DB_USER=trustuser
DB_PASS=trustpass

# Server Ports
BACKEND_PORT=5000
FRONTEND_PORT=5173

# Environment
NODE_ENV=development

# Frontend API URL
# Development: http://localhost:5000
# Production (same domain): empty
# Production (different domain): https://api.yourdomain.com:5000
VITE_API_URL=http://localhost:5000

# JWT Secret (Min 64 chars - generate new for production!)
JWT_SECRET=732e75c8cc129eab530e77aa80e48391bce1a2c83aad0ab06f72e145922790e21bc4088f0f268c27f122cd1bac1e0aa617eaadf0a9c9372a1c0b86d5049dd6a4

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
FRONTEND_URL=http://localhost:5174

# CORS Origins (comma-separated)
# Leave empty for dev (allows localhost)
# Production example: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:5174

# Third-party APIs
GEMINI_API_KEY=your-gemini-api-key
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
